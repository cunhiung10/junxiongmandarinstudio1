# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Edge TTS (Free — works without any credentials) ───────────────────────────
# Leave empty to use anonymous access. Add a trustedToken to improve reliability.
EDGE_TTS_TRUSTED_TOKEN=

# Default speakers when Volcengine credentials are NOT set (Edge TTS voices)
TTS_FEMALE_SPEAKER=zh-CN-XiaoxiaoNeural
TTS_MALE_SPEAKER=zh-CN-YunxiNeural

# ── Volcengine / Doubao 豆包 TTS (Optional — higher quality Chinese voices) ────
# Sign up at: https://www.volcengine.com/product/tts
# Then create a TTS application to get your AppID and Access Token.
VOLCANO_TTS_APP_ID=
VOLCANO_TTS_ACCESS_TOKEN=
VOLCANO_TTS_USER_ID=junxiong-user

# Doubao speaker names (only used when credentials above are filled)
TTS_FEMALE_SPEAKER_VOLCANO=灿灿
TTS_MALE_SPEAKER_VOLCANO=渐青
