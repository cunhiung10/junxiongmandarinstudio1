  "basic_strokes": [
    {
      "id": 1,
      "name_zh": "横",
      "name_pinyin": "héng",
      "name_id": "Goresan horizontal",
      "direction": "kiri → kanan",
      "example_chars": ["一", "王", "土", "三"],
      "tip": "Tulis dari kiri ke kanan dengan tekanan merata; sedikit naik di ujung."
    },
    {
      "id": 2,
      "name_zh": "竖",
      "name_pinyin": "shù",
      "name_id": "Goresan vertikal",
      "direction": "atas → bawah",
      "example_chars": ["十", "中", "木", "目"],
      "tip": "Tulis tegak lurus dari atas ke bawah; ujung bisa tumpul atau tajam."
    },
    {
      "id": 3,
      "name_zh": "撇",
      "name_pinyin": "piě",
      "name_id": "Goresan miring kiri",
      "direction": "kanan atas → kiri bawah",
      "example_chars": ["人", "大", "月", "手"],
      "tip": "Mulai dari kanan atas, turun ke kiri bawah; ujung meruncing dan terangkat."
    },
    {
      "id": 4,
      "name_zh": "捺",
      "name_pinyin": "nà",
      "name_id": "Goresan miring kanan",
      "direction": "kiri atas → kanan bawah",
      "example_chars": ["人", "大", "文", "木"],
      "tip": "Mulai tipis dari kiri atas, melebar ke kanan bawah, lalu angkat pena."
    },
    {
      "id": 5,
      "name_zh": "折",
      "name_pinyin": "zhé",
      "name_id": "Goresan tekuk",
      "direction": "berubah arah",
      "example_chars": ["口", "山", "女", "马"],
      "tip": "Goresan yang berbelok arah; paling umum adalah héng-zhé (horizontal + belok bawah)."
    },
    {
      "id": 6,
      "name_zh": "钩",
      "name_pinyin": "gōu",
      "name_id": "Goresan kait",
      "direction": "berakhir dengan kait kecil",
      "example_chars": ["子", "小", "水", "心"],
      "tip": "Goresan yang diakhiri kait kecil; arah kait bervariasi sesuai konteks."
    },
    {
      "id": 7,
      "name_zh": "点",
      "name_pinyin": "diǎn",
      "name_id": "Titik",
      "direction": "kanan atas → kiri bawah (singkat)",
      "example_chars": ["心", "六", "冰", "字"],
      "tip": "Goresan pendek menyerupai titik; ditulis dengan cepat dan penuh tekanan."
    },
    {
      "id": 8,
      "name_zh": "提",
      "name_pinyin": "tí",
      "name_id": "Goresan angkat",
      "direction": "kiri bawah → kanan atas",
      "example_chars": ["打", "地", "冰", "习"],
      "tip": "Goresan pendek naik dari kiri bawah ke kanan atas; sering muncul di sisi kiri karakter."
    }
  ],
