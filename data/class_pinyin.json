  "sandhi_rules": [
    {
      "rule": "Nada ke-3 + Nada ke-3 → Nada ke-2 + Nada ke-3",
      "example": "你好 nǐ hǎo → níhǎo",
      "note": "Saat dua nada ketiga berurutan, yang pertama berubah jadi nada ke-2"
    },
    {
      "rule": "不 (bù) sebelum nada ke-4 → bú",
      "example": "不是 bù shì → búshì",
      "note": "Negasi 不 berubah jadi nada ke-2 sebelum kata bernada ke-4"
    },
    {
      "rule": "一 (yī) berubah sesuai nada kata berikut",
      "example": "一个 yī gè → yí gè; 一天 yī tiān → yì tiān",
      "note": "一 menjadi nada ke-2 sebelum nada ke-4; nada ke-4 sebelum nada ke-1,2,3"
    }
  ]
