  "sandhi_rules": [
    {
      "id": "sandhi_t3t3",
      "name": "Nada 3 + Nada 3",
      "rule_id": "Dua nada ke-3 berurutan: yang pertama berubah menjadi nada ke-2",
      "examples": [
        {"original": "你好 nǐ hǎo", "spoken": "níhǎo", "meaning_id": "halo"},
        {"original": "可以 kě yǐ", "spoken": "kéyǐ", "meaning_id": "boleh"},
        {"original": "所以 suǒ yǐ", "spoken": "suóyǐ", "meaning_id": "oleh karena itu"},
        {"original": "手表 shǒu biǎo", "spoken": "shóubiǎo", "meaning_id": "jam tangan"}
      ]
    },
    {
      "id": "sandhi_bu",
      "name": "不 (bù) + Nada 4",
      "rule_id": "不 berubah dari nada ke-4 menjadi nada ke-2 sebelum kata bernada ke-4",
      "examples": [
        {"original": "不是 bù shì", "spoken": "búshì", "meaning_id": "bukan"},
        {"original": "不对 bù duì", "spoken": "búduì", "meaning_id": "salah"},
        {"original": "不去 bù qù", "spoken": "búqù", "meaning_id": "tidak pergi"},
        {"original": "不要 bù yào", "spoken": "búyào", "meaning_id": "tidak mau / jangan"}
      ]
    },
    {
      "id": "sandhi_yi",
      "name": "一 (yī) — perubahan nada",
      "rule_id": "一 berubah nada tergantung nada kata sesudahnya: jadi nada 2 sebelum nada 4; jadi nada 4 sebelum nada 1, 2, 3",
      "examples": [
        {"original": "一个 yī gè", "spoken": "yí gè", "meaning_id": "satu (satuan)"},
        {"original": "一天 yī tiān", "spoken": "yì tiān", "meaning_id": "satu hari"},
        {"original": "一年 yī nián", "spoken": "yì nián", "meaning_id": "satu tahun"},
        {"original": "一起 yī qǐ", "spoken": "yìqǐ", "meaning_id": "bersama"}
      ]
    }
  ],
  "common_mistakes": [
    {
      "mistake": "Menyamakan nada 2 dan 3",
      "tip": "Nada 2 hanya naik (35). Nada 3 turun dulu baru naik (214). Bedanya ada pada bagian bawah."
    },
    {
      "mistake": "Melupakan sandhi nada — mengucapkan 你好 sebagai nǐ hǎo",
      "tip": "Dalam percakapan nyata, 你好 selalu diucapkan níhǎo. Praktikkan sandhi dari awal."
    },
    {
      "mistake": "Nada 1 terdengar seperti nada 4 saat berbicara cepat",
      "tip": "Nada 1 tetap tinggi sampai akhir. Jangan biarkan turun di akhir suku kata."
    },
    {
      "mistake": "Mengabaikan nada netral — diucapkan terlalu keras",
      "tip": "Nada netral harus ringan dan pendek. Jangan diberi tekanan."
    }
  ]
